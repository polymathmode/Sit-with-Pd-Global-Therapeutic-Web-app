# Server
PORT=5000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://username:password@localhost:5432/wellbeing_db"

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Google Sign-In — OAuth 2.0 Client ID(s) from Google Cloud Console (Web application).
# Comma-separated if you use multiple clients (e.g. web + Android).
# Required for POST /api/auth/google (verify ID tokens).
GOOGLE_CLIENT_ID=
# httpOnly cookie (login/register also return token in JSON for API clients)
# JWT_COOKIE_NAME=access_token
# JWT_COOKIE_MAX_AGE_MS=604800000
# JWT_COOKIE_SECURE=false
# JWT_COOKIE_SAMESITE=lax
# JWT_COOKIE_DOMAIN=

# ── Payments ──────────────────────────────────────────────────────────────────
# Two providers are supported and can coexist; the client chooses per request
# via `provider` ("PAYSTACK" | "FLUTTERWAVE") on POST /api/payments/initialize.
# Optional `currency` (ISO code, e.g. NGN/USD/GBP) on the same body; default
# falls back to PAYMENT_DEFAULT_CURRENCY (NGN if unset).
PAYMENT_DEFAULT_CURRENCY=NGN

# Paystack
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Flutterwave (optional — only required if you accept Flutterwave on init).
# Webhook auth uses Flutterwave's static `verif-hash` header — set the same
# value here AND in the Flutterwave dashboard webhook settings.
# Webhook endpoint: POST <BASE_URL>/api/payments/flutterwave-webhook
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_WEBHOOK_HASH=
# Optional override (default https://api.flutterwave.com/v3)
# FLUTTERWAVE_API_BASE_URL=

# Cal.com → consultation auto-payment: which provider to use for the link
# emailed after a booking. Defaults to PAYSTACK.
# CONSULTATION_PAYMENT_PROVIDER=PAYSTACK

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email — on Render free tier, outbound SMTP (ports 465/587) is blocked; use Resend API key (HTTPS) instead of SMTP.
# If RESEND_API_KEY is set, it takes precedence over SMTP_*.
# Also used to sync footer newsletter signups into Resend Audiences (contacts).
# Optional: comma-separated Resend segment UUIDs — contact is POSTed after create/update.
# RESEND_NEWSLETTER_SEGMENT_IDS=
# RESEND_API_KEY=
# SMTP (local dev, or any host that allows SMTP — e.g. Render paid instance)
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=re_your_resend_api_key
EMAIL_FROM=onboarding@resend.dev
# Display name in the From: header and email footers (defaults to "Sit With PD" if unset)
EMAIL_FROM_NAME=Sit With PD


# Send all mail to this address instead of the real recipient (for Resend sandbox / testing).
# Local: set EMAIL_DEV_REDIRECT_TO only (NODE_ENV=development). Use your Resend account email.
# Render + NODE_ENV=production: also set EMAIL_REDIRECT_IN_PRODUCTION=true or redirect stays off.
# Remove both when you verify a domain and send to real users.
# EMAIL_DEV_REDIRECT_TO=you@gmail.com
# EMAIL_REDIRECT_IN_PRODUCTION=true

# App
CLIENT_URL=http://localhost:3000

# Cal.com (consultation scheduling)
CAL_WEBHOOK_SECRET=
CAL_API_KEY=
# Optional; default https://api.cal.com
# CAL_API_BASE_URL=

# Cron — HTTP triggers (optional backup for production).
#
# The server also runs matching logic on an interval from server.ts (consultation
# payment expiry, camp registration payment holds, camp status transitions).
# Configure external cron jobs when you want redundancy across deploys / cold
# starts — e.g. Render Cron hitting your public API URL with POST + Bearer token.
#
# Set CRON_SECRET and use the same value in each job's Authorization header:
#   Authorization: Bearer <CRON_SECRET>
#
# Endpoints (replace BASE_URL with your deployed API origin, no trailing slash):
#   POST BASE_URL/api/internal/cron/consultation-payment-expiry
#   POST BASE_URL/api/internal/cron/camp-registration-expiry
#   POST BASE_URL/api/internal/cron/camp-status
#
# Suggested schedule (external): every 5 minutes for expiry routes; camp-status
# can match consultation cadence or daily depending on how precise date-driven
# status changes must be.
CRON_SECRET=

# Paystack: set integration payment session timeout to 3600s (1h) to match consultation hold — global for all checkouts
# PAYSTACK_SYNC_PAYMENT_SESSION_TIMEOUT=true
# PAYSTACK_PAYMENT_SESSION_TIMEOUT_SECONDS=3600
