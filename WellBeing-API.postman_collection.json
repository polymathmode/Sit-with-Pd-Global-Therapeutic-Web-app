                { "key": "title", "value": "Introduction to Mindfulness", "type": "text" },
                { "key": "description", "value": "What mindfulness is and why it matters.", "type": "text" },
                { "key": "content", "value": "Welcome to lesson one. In this lesson we explore...", "type": "text" },
                { "key": "order", "value": "1", "type": "text" },
                { "key": "video", "type": "file", "src": "", "description": "Optional: upload a video file" },
                { "key": "file", "type": "file", "src": "", "description": "Optional: upload a PDF/document" }
              ]
            },
            "description": "Admin only. Adds a lesson to a program. Can include video upload and/or file upload."
          }
        },
        {
          "name": "[ADMIN] Update Lesson",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/programs/{{programId}}/lessons/{{lessonId}}", "host": ["{{baseUrl}}"], "path": ["api", "programs", "{{programId}}", "lessons", "{{lessonId}}"] },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title", "value": "Updated Lesson Title", "type": "text" },
                { "key": "content", "value": "Updated lesson content goes here...", "type": "text" }
