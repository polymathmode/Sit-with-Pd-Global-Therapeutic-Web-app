{
  "info": {
    "name": "Well-Being Platform API",
    "description": "Complete API collection for the Well-Being Web Platform. \n\n**Setup:**\n1. Set the `baseUrl` variable to your server (default: http://localhost:5000)\n2. Run **Register** or **Login** first — the token auto-saves to `authToken`\n3. All protected routes automatically use the saved token via collection-level auth\n\n**Seeded Admin:**\n- Email: admin@wellbeing.com\n- Password: Admin@1234",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{authToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000", "type": "string" },
    { "key": "authToken", "value": "", "type": "string" },
    { "key": "programId", "value": "", "type": "string" },
    { "key": "lessonId", "value": "", "type": "string" },
    { "key": "campId", "value": "", "type": "string" },
    { "key": "campRegistrationId", "value": "", "type": "string" },
    { "key": "serviceId", "value": "", "type": "string" },
    { "key": "consultationId", "value": "", "type": "string" },
    { "key": "paymentRef", "value": "", "type": "string" },
    { "key": "userId", "value": "", "type": "string" },
    { "key": "verifyToken", "value": "", "type": "string" }
  ],
  "item": [

    {
      "name": "🏥 Health Check",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] },
            "description": "Verify the server is running."
          }
        }
      ]
    },

    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.token) {",
                  "  pm.collectionVariables.set('authToken', res.data.token);",
                  "  console.log('Token saved:', res.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"Password123\"\n}"
            },
            "description": "Create a new user account. Sends a verification email; token is saved to `authToken`. Response user includes `isEmailVerified` (false until verified)."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.token) {",
                  "  pm.collectionVariables.set('authToken', res.data.token);",
                  "  console.log('Token saved:', res.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@wellbeing.com\",\n  \"password\": \"Admin@1234\"\n}"
            },
            "description": "Login with existing credentials. Use admin@wellbeing.com / Admin@1234 for the seeded admin account."
          }
        },
        {
          "name": "Google Sign-In",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.token) {",
                  "  pm.collectionVariables.set('authToken', res.data.token);",
                  "  console.log('Token saved:', res.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/google", "host": ["{{baseUrl}}"], "path": ["api", "auth", "google"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idToken\": \"PASTE_GOOGLE_ID_TOKEN_HERE\"\n}"
            },
            "description": "Send the Google ID token (JWT) from Google Identity Services or the mobile SDK. Set `GOOGLE_CLIENT_ID` in server `.env` to your OAuth Web Client ID. Same response shape as Login."
          }
        },
        {
          "name": "Get Current User (Me)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/auth/me", "host": ["{{baseUrl}}"], "path": ["api", "auth", "me"] },
            "description": "Returns the currently authenticated user's profile (includes isEmailVerified)."
          }
        },
        {
          "name": "Verify Email",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/auth/verify-email?token={{verifyToken}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "verify-email"],
              "query": [{ "key": "token", "value": "{{verifyToken}}" }]
            },
            "description": "Confirm email using the token from the verification email (48h expiry). Set `verifyToken` from the email link query string. Response `data` is the full public user (same fields as GET /me: id, firstName, lastName, email, role, isEmailVerified, createdAt)."
          }
        },
        {
          "name": "Resend Verification Email",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/auth/resend-verification", "host": ["{{baseUrl}}"], "path": ["api", "auth", "resend-verification"] },
            "description": "Logged-in users only. Sends a new verification link if the account is not yet verified."
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/forgot-password", "host": ["{{baseUrl}}"], "path": ["api", "auth", "forgot-password"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\"\n}"
            },
            "description": "Sends a password reset link to the provided email. Always returns 200 to prevent email enumeration."
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/reset-password", "host": ["{{baseUrl}}"], "path": ["api", "auth", "reset-password"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"PASTE_RESET_TOKEN_FROM_EMAIL_HERE\",\n  \"password\": \"NewPassword123\"\n}"
            },
            "description": "Reset the password using the token from the reset email. Token expires in 15 minutes."
          }
        }
      ]
    },

    {
      "name": "📚 Programs",
      "item": [
        {
          "name": "Get All Programs (Public)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/programs", "host": ["{{baseUrl}}"], "path": ["api", "programs"] },
            "description": "Returns all published programs. No auth required."
          }
        },
        {
          "name": "Get Program by ID (Public)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/programs/{{programId}}", "host": ["{{baseUrl}}"], "path": ["api", "programs", "{{programId}}"] },
            "description": "Returns program details and lesson titles (no video URLs until purchased)."
          }
        },
        {
          "name": "[ADMIN] Get All Programs (incl. unpublished)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/programs/admin/all", "host": ["{{baseUrl}}"], "path": ["api", "programs", "admin", "all"] },
            "description": "Admin only. Returns all programs including drafts, with lesson and purchase counts."
          }
        },
        {
          "name": "[ADMIN] Create Program",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.id) {",
                  "  pm.collectionVariables.set('programId', res.data.id);",
                  "  console.log('Program ID saved:', res.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/programs", "host": ["{{baseUrl}}"], "path": ["api", "programs"] },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title", "value": "30-Day Mindfulness Journey", "type": "text" },
                { "key": "description", "value": "Transform your mental wellness with this structured 30-day program.", "type": "text" },
                { "key": "price", "value": "25000", "type": "text" },
                { "key": "thumbnail", "type": "file", "src": "", "description": "Optional: upload a thumbnail image" }
              ]
            },
            "description": "Admin only. Creates a new program. Use form-data to optionally attach a thumbnail image."
          }
        },
        {
          "name": "[ADMIN] Update Program",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/programs/{{programId}}", "host": ["{{baseUrl}}"], "path": ["api", "programs", "{{programId}}"] },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title", "value": "Updated Program Title", "type": "text" },
                { "key": "isPublished", "value": "true", "type": "text", "description": "Set to true to publish, false to unpublish" }
              ]
            },
            "description": "Admin only. Updates any program fields. Set isPublished=true to make it visible to users."
          }
        },
        {
          "name": "[ADMIN] Delete Program",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/programs/{{programId}}", "host": ["{{baseUrl}}"], "path": ["api", "programs", "{{programId}}"] },
            "description": "Admin only. Permanently deletes a program and all its lessons."
          }
        },
