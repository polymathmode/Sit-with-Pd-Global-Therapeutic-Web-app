        {
          "name": "[ADMIN] Update Consultation Service",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/consultations/services/{{serviceId}}", "host": ["{{baseUrl}}"], "path": ["api", "consultations", "services", "{{serviceId}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 20000,\n  \"isActive\": true\n}"
            },
            "description": "Admin only. Updates a consultation service. Set isActive=false to hide it from users."
          }
        }
      ]
    },

    {
      "name": "💳 Payments",
      "item": [
        {
          "name": "[USER] Initialize Payment — Program",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.reference) {",
                  "  pm.collectionVariables.set('paymentRef', res.data.reference);",
                  "  console.log('Payment ref saved:', res.data.reference);",
                  "  console.log('Redirect user to:', res.data.authorizationUrl);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/payments/initialize", "host": ["{{baseUrl}}"], "path": ["api", "payments", "initialize"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"PROGRAM\",\n  \"itemId\": \"{{programId}}\"\n}"
            },
            "description": "Initializes a Paystack payment for a program purchase. Returns an authorizationUrl — redirect the user to this URL to complete payment."
          }
        },
        {
          "name": "[USER] Initialize Payment — Camp",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/payments/initialize", "host": ["{{baseUrl}}"], "path": ["api", "payments", "initialize"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"CAMP\",\n  \"itemId\": \"{{campRegistrationId}}\"\n}"
            },
            "description": "Initializes a Paystack payment for a camp registration. itemId must be the registration ID (not camp ID)."
          }
        },
        {
          "name": "[USER] Initialize Payment — Consultation",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/payments/initialize", "host": ["{{baseUrl}}"], "path": ["api", "payments", "initialize"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"CONSULTATION\",\n  \"itemId\": \"{{consultationId}}\"\n}"
            },
            "description": "Initializes a Paystack payment for a consultation booking."
          }
        },
        {
          "name": "Verify Payment",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/payments/verify/{{paymentRef}}", "host": ["{{baseUrl}}"], "path": ["api", "payments", "verify", "{{paymentRef}}"] },
            "description": "Check the status of a payment by its reference. Called by the frontend after Paystack redirects back."
          }
        },
        {
          "name": "[ADMIN] Get All Payments",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/payments", "host": ["{{baseUrl}}"], "path": ["api", "payments"] },
            "description": "Admin only. Returns all payment records with user details."
          }
        },
        {
          "name": "[WEBHOOK] Paystack Webhook (simulate)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-paystack-signature", "value": "COMPUTED_HMAC_SHA512_SIGNATURE", "description": "In production this is sent by Paystack automatically. For local testing use Paystack CLI." }
            ],
            "url": { "raw": "{{baseUrl}}/api/payments/webhook", "host": ["{{baseUrl}}"], "path": ["api", "payments", "webhook"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event\": \"charge.success\",\n  \"data\": {\n    \"reference\": \"{{paymentRef}}\",\n    \"amount\": 2500000,\n    \"status\": \"success\",\n    \"metadata\": {\n      \"userId\": \"USER_ID_HERE\",\n      \"type\": \"PROGRAM\",\n      \"itemId\": \"PROGRAM_ID_HERE\"\n    },\n    \"customer\": {\n      \"email\": \"john@example.com\"\n    }\n  }\n}"
            },
            "description": "⚠️ For local testing only. In production, Paystack calls this automatically. Use Paystack CLI (paystack listen) to forward real webhook events to localhost."
          }
        }
      ]
    },

    {
      "name": "📊 User Dashboard",
      "item": [
        {
          "name": "Get My Dashboard",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/dashboard", "host": ["{{baseUrl}}"], "path": ["api", "dashboard"] },
            "description": "Returns the logged-in user's purchases, camp registrations, and consultation bookings in one call."
          }
        },
        {
          "name": "Access Program Content",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/dashboard/programs/{{programId}}", "host": ["{{baseUrl}}"], "path": ["api", "dashboard", "programs", "{{programId}}"] },
            "description": "Returns full lesson content (including video URLs) for a purchased program. Returns 403 if not purchased."
          }
        }
      ]
    },

    {
      "name": "⚙️ Admin",
      "item": [
        {
          "name": "Get Dashboard Stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/admin/stats", "host": ["{{baseUrl}}"], "path": ["api", "admin", "stats"] },
            "description": "Admin only. Returns platform overview: total users, programs, camps, consultations, total revenue, and recent payments."
          }
        },
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/admin/users?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "users"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            },
            "description": "Admin only. Paginated list of all registered users with purchase/booking counts."
          }
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/admin/users/{{userId}}", "host": ["{{baseUrl}}"], "path": ["api", "admin", "users", "{{userId}}"] },
            "description": "Admin only. Full user profile including all purchases, camp registrations, consultations, and payment history."
          }
        }
      ]
    }

  ]
}
