                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/programs/{{programId}}/lessons", "host": ["{{baseUrl}}"], "path": ["api", "programs", "{{programId}}", "lessons"] },
            "body": {
