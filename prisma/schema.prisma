// This is your Prisma schema file
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum PaymentType {
  PROGRAM
  CAMP
  CONSULTATION
}

enum ConsultationStatus {
  PENDING
  PENDING_PAYMENT // Cal.com slot held; awaiting Paystack within paymentExpiresAt
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum CampStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

// ─────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────

model User {
  id                String    @id @default(cuid())
  firstName         String
  lastName          String
  email             String    @unique
  password          String
  role              Role      @default(USER)
  isEmailVerified   Boolean   @default(false)
  passwordResetToken  String?
  passwordResetExpiry DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  purchases         Purchase[]
  campRegistrations CampRegistration[]
  consultations     Consultation[]
  payments          Payment[]

  @@map("users")
}

// ─────────────────────────────────────────────
// PROGRAMS (Courses)
// ─────────────────────────────────────────────

model Program {
  id          String   @id @default(cuid())
  title       String
  description String
  price       Float
  thumbnail   String?  // Cloudinary URL
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  lessons     Lesson[]
  purchases   Purchase[]

  @@map("programs")
}

model Lesson {
  id          String   @id @default(cuid())
  programId   String
  title       String
  description String?
  videoUrl    String?  // Cloudinary URL
  fileUrl     String?  // Cloudinary URL (PDFs, downloads)
  content     String?  // Written lesson text
  order       Int      // Lesson order within the program
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  program     Program  @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@map("lessons")
}

model Purchase {
  id        String   @id @default(cuid())
  userId    String
  programId String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  program   Program  @relation(fields: [programId], references: [id])
  payment   Payment?

  @@unique([userId, programId]) // A user can only purchase a program once
  @@map("purchases")
}

// ─────────────────────────────────────────────
// CAMPS
// ─────────────────────────────────────────────

model Camp {
  id          String     @id @default(cuid())
  title       String
  description String
  location    String
  price       Float
  capacity    Int
  startDate   DateTime
  endDate     DateTime
  thumbnail   String?    // Cloudinary URL
  status      CampStatus @default(UPCOMING)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Relations
  registrations CampRegistration[]

  @@map("camps")
}

model CampRegistration {
  id        String   @id @default(cuid())
  userId    String
  campId    String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  camp      Camp     @relation(fields: [campId], references: [id])
  payment   Payment?

  @@unique([userId, campId]) // A user can only register for a camp once
  @@map("camp_registrations")
}

// ─────────────────────────────────────────────
// CONSULTATIONS
// ─────────────────────────────────────────────

model ConsultationService {
  id          String   @id @default(cuid())
  title       String
  description String
  price       Float
  duration    Int      // Duration in minutes
  /// Cal.com Event Type ID — set in Cal.com dashboard; used to map webhooks to this service
  calEventTypeId Int?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  consultations Consultation[]

  @@map("consultation_services")
}

model Consultation {
  id            String             @id @default(cuid())
  userId        String
  serviceId     String
  preferredDate DateTime?          // User's requested date
  confirmedDate DateTime?        // Slot time from Cal.com or admin
  notes         String?            // User notes / special requests
  status        ConsultationStatus @default(PENDING)
  /// Cal.com booking UID (payload.uid) — unique when set
  calBookingId  String?            @unique
  /// Link to manage booking in Cal.com (e.g. bookerUrl)
  calBookingUrl String?
  /// Paystack must complete before this time or slot is released (1h from BOOKING_CREATED)
  paymentExpiresAt DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  user          User               @relation(fields: [userId], references: [id])
  service       ConsultationService @relation(fields: [serviceId], references: [id])
  payment       Payment?

  @@map("consultations")
}

// ─────────────────────────────────────────────
// PAYMENTS
// ─────────────────────────────────────────────

model Payment {
  id               String        @id @default(cuid())
  userId           String
  type             PaymentType
  amount           Float
  currency         String        @default("NGN")
  status           PaymentStatus @default(PENDING)
  paystackRef      String        @unique // Paystack transaction reference
  paystackResponse Json?         // Full Paystack webhook response stored for records

  // Foreign keys (only one will be set depending on payment type)
  purchaseId       String?       @unique
  campRegistrationId String?     @unique
  consultationId   String?       @unique

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  // Relations
  user             User          @relation(fields: [userId], references: [id])
  purchase         Purchase?     @relation(fields: [purchaseId], references: [id])
  campRegistration CampRegistration? @relation(fields: [campRegistrationId], references: [id])
  consultation     Consultation? @relation(fields: [consultationId], references: [id])

  @@map("payments")
}
