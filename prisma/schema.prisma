generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum PaymentType {
  PROGRAM
  CAMP
  CONSULTATION
}

enum ConsultationStatus {
  PENDING
  PENDING_PAYMENT
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum CampStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

// Blog listing filters (design: Reflection, Wellbeing, Personal Growth)
enum BlogCategory {
  REFLECTION
  WELLBEING
  PERSONAL_GROWTH
}

// Matches the "Type" field in the Add Module modal (Reading, Video, Quiz, etc.)
enum ModuleType {
  VIDEO
  READING
  QUIZ
  ASSIGNMENT
  OTHER
}

// Admin dashboard — Platform Settings page (singleton row id `default`)
enum PlatformCurrency {
  NGN
  USD
  EUR
  GBP
}

model PlatformSettings {
  id                        String           @id @default("default")
  platformName              String           @default("Sit With PD")
  supportEmail              String           @default("support@sitwithpd.com")
  defaultTimezone           String           @default("Africa/Lagos")
  currency                  PlatformCurrency @default(NGN)
  maintenanceMode           Boolean          @default(false)
  allowUserRegistration     Boolean          @default(true)
  requireEmailVerification  Boolean          @default(true)
  autoEnrollment            Boolean          @default(false)
  emailNotificationsEnabled Boolean          @default(true)
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt

  @@map("platform_settings")
}

model User {
  id                      String    @id @default(cuid())
  firstName               String
  lastName                String
  email                   String    @unique
  password                String?
  googleId                String?   @unique
  role                    Role      @default(USER)
  isEmailVerified         Boolean   @default(false)
  emailVerificationToken  String?
  emailVerificationExpiry DateTime?
  passwordResetToken      String?
  passwordResetExpiry     DateTime?
  phone                   String?
  timezone                String?
  notifyEmail             Boolean   @default(true)
  notifyProgramReminders  Boolean   @default(false)
  notifyPush              Boolean   @default(true)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  purchases         Purchase[]
  campRegistrations CampRegistration[]
  consultations     Consultation[]
  payments          Payment[]

  @@map("users")
}

// Matches the Program Type dropdown: Leaders, Students, Professionals
enum ProgramCategory {
  LEADERS
  STUDENTS
  PROFESSIONALS
}

model Program {
  id               String          @id @default(cuid())
  title            String
  description      String
  price            Float
  category         ProgramCategory @default(LEADERS)
  thumbnail        String?
  isPublished      Boolean         @default(false)
  durationWeeks    Int?
  hoursPerWeek     Float?
  certificateLabel String?
  learningOutcomes String[] // Program-level learning objectives (Step 2 of form)
  startDate        DateTime?
  facilitatorName  String?
  facilitatorEmail String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  // Three-level hierarchy: Program → Week → Module
  weeks     ProgramWeek[]
  purchases Purchase[]

  @@map("programs")
}

// Represents a "Week" in the Program Weeks section of the design.
// Each week has a title, description, its own learning objectives, and child modules.
model ProgramWeek {
  id                 String   @id @default(cuid())
  programId          String
  title              String
  description        String?
  learningObjectives String[] // Per-week learning objectives added via the modal
  order              Int // Determines "Week 1", "Week 2" display order

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  program Program         @relation(fields: [programId], references: [id], onDelete: Cascade)
  modules ProgramModule[]

  @@map("program_weeks")
}

// Represents a "Module" inside a week.
// Fields map directly to the "Add Module to Week" modal in the design.
model ProgramModule {
  id          String     @id @default(cuid())
  weekId      String
  title       String
  description String?
  type        ModuleType @default(OTHER)
  duration    String? // Free-text: "45 min", "1 hr", etc. (matches the design's Duration field)
  contentUrl  String? // YouTube, Vimeo, Google Docs URL (Content URL field)
  embedCode   String? // Raw iframe/HTML embed (Embed Code field)
  order       Int // Module display order within the week

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  week ProgramWeek @relation(fields: [weekId], references: [id], onDelete: Cascade)

  @@map("program_modules")
}

model Purchase {
  id        String   @id @default(cuid())
  userId    String
  programId String
  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id])
  program Program  @relation(fields: [programId], references: [id])
  payment Payment?

  @@unique([userId, programId])
  @@map("purchases")
}

model Camp {
  id          String     @id @default(cuid())
  title       String
  description String
  location    String
  // Optional fallback/display price. Source of truth for registration amount is the selected CampTier.
  price       Float?
  currency    String     @default("USD")
  capacity    Int // Total seats across all tiers (sum of registration.participantCount must not exceed this)
  startDate   DateTime
  endDate     DateTime
  thumbnail   String?
  benefits    String[] // "Why Attend" bullet list (e.g. "Pause and reconnect with yourself")
  status      CampStatus @default(UPCOMING)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  tiers         CampTier[]
  images        CampImage[]
  testimonials  Testimonial[]
  registrations CampRegistration[]

  @@map("camps")
}

// Participation packages (e.g. Individual $500, Couple $750, Family $1500).
model CampTier {
  id           String   @id @default(cuid())
  campId       String
  label        String // "Individual", "Couple", "Family", etc.
  description  String?
  price        Float
  inclusions   String[] // ["Accommodation", "Meals", "Guided sessions", ...]
  seatsPerUnit Int      @default(1) // 1 for Individual, 2 for Couple, 4-5 for Family — consumed from camp.capacity
  maxUnits     Int? // Optional cap on how many of this tier can be sold (null = only bound by camp capacity)
  order        Int      @default(0)
  isFeatured   Boolean  @default(false) // Design highlights the middle tier (Couple)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  camp          Camp               @relation(fields: [campId], references: [id], onDelete: Cascade)
  registrations CampRegistration[]

  @@unique([campId, label])
  @@map("camp_tiers")
}

// Gallery photos for the "A Glimpse Into the Experience" section.
model CampImage {
  id        String   @id @default(cuid())
  campId    String
  url       String
  caption   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  camp Camp @relation(fields: [campId], references: [id], onDelete: Cascade)

  @@map("camp_images")
}

// Testimonials for camps (campId) or site-wide (campId = null).
model Testimonial {
  id          String   @id @default(cuid())
  campId      String?
  name        String
  role        String? // "Camp Participant", "Camp Attendee", "Program Student", etc.
  quote       String
  avatarUrl   String?
  isPublished Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  camp Camp? @relation(fields: [campId], references: [id], onDelete: SetNull)

  @@map("testimonials")
}

model BlogPost {
  id              String       @id @default(cuid())
  slug            String       @unique
  title           String
  excerpt         String
  body            String
  readTimeMinutes Int          @default(5)
  category        BlogCategory
  coverImageUrl   String?
  isPublished     Boolean      @default(false)
  publishedAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@map("blog_posts")
}

model CampRegistration {
  id               String   @id @default(cuid())
  userId           String
  campId           String
  tierId           String?
  participantCount Int      @default(1) // Seats consumed (copied from tier.seatsPerUnit at creation)
  applicantDetails Json? // Dietary, emergency contact, partner/family names, accommodation prefs, etc.
  createdAt        DateTime @default(now())

  user    User      @relation(fields: [userId], references: [id])
  camp    Camp      @relation(fields: [campId], references: [id])
  tier    CampTier? @relation(fields: [tierId], references: [id], onDelete: SetNull)
  payment Payment?

  @@unique([userId, campId])
  @@map("camp_registrations")
}

model ConsultationService {
  id             String   @id @default(cuid())
  title          String
  description    String
  price          Float
  duration       Int
  calEventTypeId Int?
  calBookingUrl  String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  consultations Consultation[]

  @@unique([calEventTypeId])
  @@map("consultation_services")
}

model Consultation {
  id               String             @id @default(cuid())
  userId           String
  serviceId        String
  preferredDate    DateTime?
  confirmedDate    DateTime?
  notes            String?
  status           ConsultationStatus @default(PENDING)
  calBookingId     String?            @unique
  calBookingUrl    String?
  paymentExpiresAt DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  user    User                @relation(fields: [userId], references: [id])
  service ConsultationService @relation(fields: [serviceId], references: [id])
  payment Payment?

  @@map("consultations")
}

model Payment {
  id                 String        @id @default(cuid())
  userId             String
  type               PaymentType
  amount             Float
  currency           String        @default("NGN")
  status             PaymentStatus @default(PENDING)
  paystackRef        String        @unique
  paystackResponse   Json?
  purchaseId         String?       @unique
  campRegistrationId String?       @unique
  consultationId     String?       @unique
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  user             User              @relation(fields: [userId], references: [id])
  purchase         Purchase?         @relation(fields: [purchaseId], references: [id])
  campRegistration CampRegistration? @relation(fields: [campRegistrationId], references: [id])
  consultation     Consultation?     @relation(fields: [consultationId], references: [id])

  @@map("payments")
}
