generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum PaymentType {
  PROGRAM
  CAMP
  CONSULTATION
}

enum ConsultationStatus {
  PENDING
  PENDING_PAYMENT
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum CampStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

model User {
  id                       String    @id @default(cuid())
  firstName                String
  lastName                 String
  email                    String    @unique
  password                 String?
  googleId                 String?   @unique
  role                     Role      @default(USER)
  isEmailVerified          Boolean   @default(false)
  emailVerificationToken   String?
  emailVerificationExpiry  DateTime?
  passwordResetToken       String?
  passwordResetExpiry      DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  purchases         Purchase[]
  campRegistrations CampRegistration[]
  consultations     Consultation[]
  payments          Payment[]

  @@map("users")
}


enum ProgramDeliveryFormat {
  ONLINE
  IN_PERSON
  HYBRID
}

model Program {
  id               String                @id @default(cuid())
  title            String
  description      String
  summary          String?
  category         String?
  price            Float
  thumbnail        String?
  isPublished      Boolean               @default(false)
  durationWeeks    Int?
  hoursPerWeek     Float?
  deliveryFormat   ProgramDeliveryFormat @default(ONLINE)
  certificateLabel String?
  learningOutcomes String[]
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  lessons          Lesson[]
  purchases        Purchase[]

  @@map("programs")
}

model Lesson {
  id          String   @id @default(cuid())
  programId   String
  title       String
  description String?
  videoUrl    String?
  fileUrl     String?
  content     String?
  order       Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  program     Program  @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@map("lessons")
}

model Purchase {
  id        String   @id @default(cuid())
  userId    String
  programId String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  program   Program  @relation(fields: [programId], references: [id])
  payment   Payment?

  @@unique([userId, programId])
  @@map("purchases")
}

model Camp {
  id          String     @id @default(cuid())
  title       String
  description String
  location    String
  price       Float
  capacity    Int
  startDate   DateTime
  endDate     DateTime
  thumbnail   String?
  status      CampStatus @default(UPCOMING)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  registrations CampRegistration[]

  @@map("camps")
}

model CampRegistration {
  id        String   @id @default(cuid())
  userId    String
  campId    String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  camp      Camp     @relation(fields: [campId], references: [id])
  payment   Payment?

  @@unique([userId, campId])
  @@map("camp_registrations")
}

model ConsultationService {
  id             String   @id @default(cuid())
  title          String
  description    String
  price          Float
  duration       Int
  calEventTypeId Int?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  consultations Consultation[]

  @@map("consultation_services")
}

model Consultation {
  id              String             @id @default(cuid())
  userId          String
  serviceId       String
  preferredDate   DateTime?
  confirmedDate   DateTime?
  notes           String?
  status          ConsultationStatus @default(PENDING)
  calBookingId    String?            @unique
  calBookingUrl   String?
  paymentExpiresAt DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  user            User               @relation(fields: [userId], references: [id])
  service         ConsultationService @relation(fields: [serviceId], references: [id])
  payment         Payment?

  @@map("consultations")
}

model Payment {
  id                 String        @id @default(cuid())
  userId             String
  type               PaymentType
  amount             Float
  currency           String        @default("NGN")
  status             PaymentStatus @default(PENDING)
  paystackRef        String        @unique
  paystackResponse   Json?
  purchaseId         String?       @unique
  campRegistrationId String?       @unique
  consultationId     String?       @unique
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  user             User              @relation(fields: [userId], references: [id])
  purchase         Purchase?         @relation(fields: [purchaseId], references: [id])
  campRegistration CampRegistration? @relation(fields: [campRegistrationId], references: [id])
  consultation     Consultation?     @relation(fields: [consultationId], references: [id])

  @@map("payments")
}